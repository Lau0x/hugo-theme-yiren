{{- $pages := where site.RegularPages "Section" "in" (site.Params.mainSections | default (slice "posts")) -}}
[
{{- range $i, $page := $pages -}}
  {{- if $i }},{{ end -}}
  {
    "title": {{ $page.Title | jsonify }},
    "permalink": {{ $page.RelPermalink | jsonify }},
    "summary": {{ ($page.Summary | plainify) | jsonify }},
    "content": {{ ($page.Plain | truncate 1200) | jsonify }},
    "date": {{ $page.Date.Format "2006-01-02" | jsonify }},
    "tags": {{ $page.Params.tags | default slice | jsonify }}
  }
{{- end -}}
]
